@startuml First_Faults_GUI Project Structure

skinparam packageStyle rectangle
skinparam linetype ortho

title First_Faults_GUI - Project Structure

package "First_Faults_GUI" {

    package "business" <<Layer>> {
        package "core" {
            [singleton.py]
            [formatters.py]
            [tree_builder.py]
            [fault_count_service.py] as fcs
        }

        package "services" {
            [analyzer.py] as bsa
        }

        package "utils" {
            [cli.py]
            [print_result.py]
            [fault_count_formatter.py]
            [mail_service.py]
        }
    }

    package "data" <<Layer>> {
        package "model" {
            [models.py]
        }

        package "orm" {
            [reporting_orm.py]
        }

        package "repositories" {
            [repository.py]
            [snapshot_repository.py] as snaprepo
            [DB_Connection.py]
        }

        package "schemas" {
            [prod_sql.sql]
            [reporting.sql]
            [Create database.sql]
            folder "SQL Tests" {
            }
        }
    }

    package "presentations" <<Layer>> {
        [app.py]
        [plc.py]

        package "services" as ps {
            [diagram_service_view.py] as dsv
            [pdf_generator.py]
            [creadential.py]
            [credential_service.py]
        }

        package "static" {
            [style.css]
        }

        package "templates" {
            [base.html]
            [home.html]
            [about.html]
            [contact.html]
            [diagrams.html]
            [form.html]
            [table.html]
            [table_tree.html]
        }
    }

    package "scripts" {
        [backfill_snapshots.py]
        [check_fault_counts.py]
        [migrate.py]
    }

    package "tests" {
        [analyze_trends.py]
        [fault_analyzer.py]
        [fault_predictor.py]
        [ml_pipeline.py]
        [snapshot_manager.py]
    }

    package "config" {
        [config.toml]
    }

    [run_interlock.py] as entry
    [run_daily_snapshot.py] as daily
    [pyproject.toml]
    [README.md]
}

' Dependencies
entry --> bsa
bsa --> [tree_builder.py]
bsa --> [formatters.py]
bsa --> [repository.py]
bsa --> [models.py]
[tree_builder.py] --> [models.py]
[repository.py] --> [DB_Connection.py]
snaprepo --> [DB_Connection.py]
snaprepo --> [reporting_orm.py]
[app.py] --> [plc.py]
[plc.py] --> bsa
[plc.py] --> dsv
[plc.py] --> fcs
dsv --> snaprepo
dsv --> fcs
fcs --> [repository.py]
daily --> snaprepo
daily --> fcs

note right of "business"
  Business Logic Layer
  - Core algorithms & services
  - Fault count & trend analysis
  - Utilities (mail, CLI, formatting)
end note

note right of "data"
  Data Access Layer
  - Domain models & ORM
  - Repositories (interlock + snapshots)
  - SQL schemas & migrations
end note

note right of "presentations"
  Presentation Layer
  - Flask web application
  - Diagram & PDF services
  - HTML templates & static assets
end note

@enduml
